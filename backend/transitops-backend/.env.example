# Server
PORT=4000
NODE_ENV=development

# Database (Neon / any Postgres connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/transitops?sslmode=require"

# Auth
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="2h"

# CORS - the origin of whatever frontend/test client will call this API
CORS_ORIGIN="http://localhost:5173"

# Optional AI service (bonus features - safe to leave blank for core MVP)
ANTHROPIC_API_KEY=""
AI_RISK_SERVICE_URL="http://localhost:8000"
